---
import Layout from "../layouts/layout.astro";
import Header from "../components/header.astro";
import SportCard from "../components/sportsCard.astro";
import { getEnrichedSports } from "../lib/sportsService";
import MatchCard from "../components/matchcard.astro";
import LiveCard from "../components/livecard.astro";
// Fetch enriched sports (cached – see sportsService.ts)
const allSports = await getEnrichedSports();

// Only active sports with an image from leagueImages.ts
const sportsWithImage = allSports.filter(
  (sport) => sport.active && sport.image !== null,
);
// Datos para la sección destacados
const matches = [
  {
    league: "La Liga",
    team1: "Real Madrid",
    team2: "Barcelona",
    time: "18:00",
    odds: { home: "2.10", draw: "3.20", away: "4.50" },
    isPopular: true,
  },
  {
    league: "Premier League",
    team1: "Liverpool",
    team2: "Man City",
    time: "20:00",
    odds: { home: "1.85", draw: "3.40", away: "5.20" },
  },
];

---

<Layout title="OddLines | Apuestas Deportivas">
  <Header />

  <main class="main-content">
    <!-- Deportes: fila horizontal como las tarjetas originales -->
    <section class="sports-section">
      <div class="section-header">
        <div class="title-group">
          <div class="title-accent-bar featured-bar"></div>
          <h2 class="section-title">Deportes</h2>
        </div>
      </div>

      <div class="sports-scroll-container">
        {
          sportsWithImage.map((sport) => (
            <SportCard
              imageSrc={sport.image!}
              value={sport.title}
              label={sport.group}
            />
          ))
        }
      </div>
    </section>

    <!-- Destacados -->
    <section class="featured-section">
      <div class="section-header">
        <div class="title-group">
          <div class="title-accent-bar featured-bar"></div>
          <h2 class="section-title">Destacados</h2>
        </div>
        <a href="#" class="view-all-link">Ver Todos</a>
      </div>

      <div class="matches-scroll-container">
        {matches.map((match) => <MatchCard {...match} />)}
      </div>
    </section>

    <!-- En Vivo -->
    <section class="live-section">
      <div class="section-header">
        <div class="title-group">
          <div class="live-indicator-dot"></div>
          <div class="title-accent-bar"></div>
          <h2 class="section-title">En Vivo</h2>
        </div>
        <a href="#" class="view-all-link">
          Ver Todos
          <svg
            width="16"
            height="16"
            viewBox="0 0 16 16"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M6 4L10 8L6 12"
              stroke="#00D492"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>

      <div class="live-list">
        <LiveCard
          time="67'"
          team1="Atlético Madrid"
          score1="2"
          team2="Valencia CF"
          score2="1"
        />
        <LiveCard
          time="89'"
          team1="Arsenal"
          score1="3"
          team2="Chelsea"
          score2="2"
        />
      </div>
    </section>
  </main>
</Layout>

<style>
  .container {
    padding: 16px;
    width: 100%;
  }

  .stats-container {
    display: flex;
    width: 100%;
    gap: 10px;
    justify-content: space-between;
    padding: 16px;
  }

  /* Deportes: fila horizontal con scroll */
  .sports-section {
    padding: 16px 0 16px 16px;
  }

  .sports-scroll-container {
    display: flex;
    gap: 10px;
    padding: 4px 16px 12px 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .sports-scroll-container::-webkit-scrollbar {
    display: none;
  }

  /* Encabezados reutilizables */
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding: 0 4px;
  }

  .title-group {
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
  }

  .live-indicator-dot {
    width: 12px;
    height: 12px;
    background: #fb2c36;
    border-radius: 50%;
    box-shadow: 0px 0px 10px rgba(251, 44, 54, 0.5);
  }

  .title-accent-bar {
    width: 4px;
    height: 24px;
    background: linear-gradient(180deg, #fb2c36 0%, #e7000b 100%);
    border-radius: 20px;
  }

  .featured-bar {
    background: linear-gradient(180deg, #05dfaf 0%, #05dfaf 100%);
  }

  .section-title {
    color: white;
    font-size: 18px;
    font-weight: 900;
    margin: 0;
    font-family: "Open sans", sans-serif;
  }

  .view-all-link {
    color: #05dfaf;
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Destacados: scroll horizontal */
  .featured-section {
    padding: 16px 0 16px 16px;
  }

  .matches-scroll-container {
    display: flex;
    gap: 16px;
    padding: 0 16px 20px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .matches-scroll-container::-webkit-scrollbar {
    display: none;
  }

  /* En Vivo */
  .live-section {
    padding: 16px 0 16px 16px;
    background: linear-gradient(
      180deg,
      rgba(251, 44, 54, 0.05) 0%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .live-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
</style>
