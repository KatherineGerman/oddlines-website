---
/* Navigation.astro */
---

<nav class="bottom-nav">
  <a href="/" class="nav-item active">
    <div class="icon">
      <div class="home-icon">
        <div class="chimney"></div>
      </div>
    </div>
    <span>Inicio</span>
  </a>

  <a href="/deportes" class="nav-item">
    <div class="icon">
      <div class="sports-icon">
        <div class="ball"></div>
      </div>
    </div>
    <span>Deportes</span>
  </a>

  <a href="/en-vivo" class="nav-item">
    <div class="icon">
      <div class="live-icon"></div>
    </div>
    <span>En Vivo</span>
  </a>

  <a href="/cuenta" class="nav-item">
    <div class="icon">
      <div class="user-icon">
        <div class="head"></div>
        <div class="body"></div>
      </div>
    </div>
    <span>Cuenta</span>
  </a>
</nav>

<style>
  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    max-width: 480px; /* Se ajusta a tu mobile wrapper */
    height: 70px;
    background: rgba(21, 27, 45, 0.95);
    backdrop-filter: blur(10px);
    border-top: 0.67px solid rgba(255, 255, 255, 0.10);
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding-bottom: env(safe-area-inset-bottom); /* Para iPhones con notch abajo */
    z-index: 1000;
  }

  .nav-item {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
    transition: all 0.2s ease;
  }

  .nav-item span {
    font-size: 10px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.50);
  }

  .nav-item.active span {
    color: #05dfaf;
  }

  /* --- ICONOS ESTILIZADOS --- */
  .icon {
    width: 24px;
    height: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  /* Inicio */
  .home-icon {
    width: 16px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 2px;
  }
  .active .home-icon { border-color: #05dfaf; }

  /* Deportes */
  .ball {
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 50%;
  }
  .active .ball { border-color: #05dfaf; }

  /* En Vivo */
  .live-icon {
    width: 18px;
    height: 14px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 2px;
  }
  .active .live-icon { border-color: #05dfaf; }

  /* Cuenta */
  .user-icon .head {
    width: 6px;
    height: 6px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 50%;
    margin-bottom: 2px;
  }
  .user-icon .body {
    width: 14px;
    height: 6px;
    border: 2px solid rgba(255, 255, 255, 0.5);
    border-radius: 4px 4px 0 0;
  }
  .active .user-icon .head, .active .user-icon .body { border-color: #05dfaf; }
</style>