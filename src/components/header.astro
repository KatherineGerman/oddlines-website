---
/* Aquí puedes añadir lógica de JS si la necesitas más adelante */
---

<header class="header">
  <!-- Lado Izquierdo: Logo -->
  <div class="logo-container">
    <div class="logo-icon">
      <div class="icon-shape"></div>
    </div>
    <span class="brand-name">OddLines</span>
  </div>

  <!-- Lado Derecho: Acciones -->
  <div class="actions">
    <!-- Botón de Búsqueda/Lupa -->
    <button class="icon-btn">
      <div class="search-icon">
        <div class="circle"></div>
        <div class="line"></div>
      </div>
    </button>

    <!-- Botón Login -->
    <button class="btn-login">
      Iniciar Sesión
    </button>

    <!-- Botón Registro -->
    <button class="btn-register">
      Registro
    </button>
  </div>
</header>

<style>
  .header {
    width: 100%;
    padding: 16px;
    background: rgba(21, 27, 45, 0.80);
    backdrop-filter: blur(12px);
    box-shadow: 0px 4px 6px -4px rgba(0, 0, 0, 0.10), 0px 10px 15px -3px rgba(0, 0, 0, 0.10);
    border-bottom: 0.67px solid rgba(255, 255, 255, 0.10);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  /* --- LOGO STYLES --- */
  .logo-container {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #00BC7D 0%, #009966 100%);
    box-shadow: 0px 4px 10px rgba(0, 188, 125, 0.30);
    border-radius: 50%; /* Limpiamos el número gigante de Figma */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .icon-shape {
    width: 16px;
    height: 16px;
    border: 2px solid white;
    border-radius: 2px;
  }

  .brand-name {
    color: white;
    font-size: 18px;
    font-weight: 900;
    font-family: 'Inter', sans-serif;
  }

  /* --- ACTIONS STYLES --- */
  .actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .icon-btn {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    border: 0.67px solid rgba(255, 255, 255, 0.10);
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }

  /* Recreación de la lupa de Figma */
  .search-icon {
    width: 20px;
    height: 20px;
    position: relative;
  }
  .search-icon .circle {
    width: 12px;
    height: 12px;
    border: 1.67px solid rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    position: absolute;
    top: 2px;
    left: 2px;
  }
  .search-icon .line {
    width: 5px;
    height: 1.67px;
    background: rgba(255, 255, 255, 0.7);
    position: absolute;
    bottom: 3px;
    right: 2px;
    transform: rotate(45deg);
  }

  .btn-login {
    background: transparent;
    color: white;
    font-size: 12px;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 100px;
    border: 0.67px solid rgba(255, 255, 255, 0.20);
    cursor: pointer;
  }

  .btn-register {
    background: linear-gradient(90deg, #00BC7D 0%, #009966 100%);
    color: white;
    font-size: 12px;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 100px;
    border: none;
    cursor: pointer;
  }
</style>