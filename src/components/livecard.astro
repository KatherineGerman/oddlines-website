---
interface Props {
  time: string;
  team1: string;
  team2: string;
  score1: string;
  score2: string;
}

const { time, team1, team2, score1, score2 } = Astro.props;
---

<div class="live-card">
  <div class="card-header">
    <div class="live-badge">
      <div class="dot"></div>
      <span>LIVE</span>
    </div>
    <div class="time-badge">{time}</div>
  </div>

  <div class="teams-container">
    <div class="team-row">
      <div class="team-info">
        <div class="logo-placeholder"></div>
        <span class="team-name">{team1}</span>
      </div>
      <span class="score">{score1}</span>
    </div>
    
    <div class="divider"></div>

    <div class="team-row">
      <div class="team-info">
        <div class="logo-placeholder"></div>
        <span class="team-name">{team2}</span>
      </div>
      <span class="score">{score2}</span>
    </div>
  </div>
</div>

<style>
  .live-card {
    align-self: stretch;
    padding: 20px;
    background: linear-gradient(135deg, rgba(21, 27, 45, 0.80) 0%, rgba(15, 20, 25, 0.80) 100%);
    border-radius: 24px;
    border: 0.67px solid rgba(251, 44, 54, 0.30); /* Borde rojizo sutil de tu Figma */
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 12px;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .live-badge {
    background: linear-gradient(90deg, #FB2C36 0%, #E7000B 100%);
    padding: 6px 12px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
  }

  .dot {
    width: 8px;
    height: 8px;
    background: white;
    border-radius: 50%;
    opacity: 0.8;
  }

  .live-badge span {
    color: white;
    font-size: 12px;
    font-weight: 900;
  }

  .time-badge {
    background: rgba(255, 255, 255, 0.10);
    padding: 8px 12px;
    border-radius: 20px;
    color: #00D492;
    font-size: 12px;
    font-weight: 700;
    border: 0.67px solid rgba(255, 255, 255, 0.20);
  }

  .teams-container {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .team-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .team-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-placeholder {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    border: 0.67px solid rgba(255, 255, 255, 0.1);
  }

  .team-name {
    color: white;
    font-size: 16px;
    font-weight: 700;
  }

  .score {
    color: white;
    font-size: 24px;
    font-weight: 900;
  }

  .divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.1) 50%, transparent 100%);
  }
</style>