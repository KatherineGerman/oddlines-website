---
interface Props {
  league: string;
  team1: string;
  team2: string;
  time: string;
  odds: {
    home: string;
    draw: string;
    away: string;
  };
  isPopular?: boolean;
}

const { league, team1, team2, time, odds, isPopular } = Astro.props;
---

<div class="match-card">
  <!-- Always render a badge container – visible only when popular -->
  <div class="badge-area">
    {isPopular ? (
      <div class="badge-popular">
        <span class="badge-text">Popular</span>
      </div>
    ) : (
      <div class="badge-placeholder"></div>
    )}
  </div>

  <div class="match-info">
    <div class="league-name">{league}</div>
    
    <div class="teams">
      <div class="team">
        <div class="team-logo-placeholder"></div>
        <span>{team1}</span>
      </div>
      <div class="team">
        <div class="team-logo-placeholder"></div>
        <span>{team2}</span>
      </div>
    </div>
  </div>

  <div class="time-badge">
    <span class="icon-clock">⏱</span>
    <span>{time}</span>
  </div>

  <div class="odds-container">
    <div class="odd-box">
      <span class="odd-label">1</span>
      <span class="odd-value">{odds.home}</span>
    </div>
    <div class="odd-box">
      <span class="odd-label">X</span>
      <span class="odd-value">{odds.draw}</span>
    </div>
    <div class="odd-box">
      <span class="odd-label">2</span>
      <span class="odd-value">{odds.away}</span>
    </div>
  </div>
</div>

<style>
  .match-card {
    width: 410px;
    min-width: 410px;
    max-width: 410px;
    height:300px;
    min-height:300px;
    max-height:300px;
    overflow: hidden;
    
    padding: 20px;
    background: linear-gradient(135deg, rgba(21, 27, 45, 0.8) 0%, rgba(15, 20, 25, 0.8) 100%);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    gap: 10px;
    box-sizing: border-box;
  }

  /* Area always has the same height (badge + its margin) */
  .badge-area {
    min-height: 24px;           /* enough to hold the badge + its natural margins */
    display: flex;
    align-items: center;
  }

  .badge-popular {
    padding: 2px 10px;
    background: rgba(254, 154, 0, 0.2);
    border-radius: 100px;
    border: 1px solid rgba(254, 154, 0, 0.3);
    color: #FFB900;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .badge-placeholder {
    /* Invisible, but takes up same height as the badge */
    width: 1px;
    height: 24px;              /* match the badge's line height */
    visibility: hidden;
  }

  .league-name {
    text-align: center;
    color: #05dfaf;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 8px;
  }

  .teams {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .team {
    display: flex;
    align-items: center;
    gap: 12px;
    color: white;
    font-weight: 700;
    font-size: 15px;
  }

  .team-logo-placeholder {
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 14px;
  }

  .time-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    color: white;
    font-size: 13px;
    font-weight: 700;
  }

  .odds-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .odd-box {
    padding: 8px 4px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .odd-label {
    color: rgba(255, 255, 255, 0.6);
    font-size: 12px;
    font-weight: 700;
  }

  .odd-value {
    color: white;
    font-size: 10px;
    font-weight: 900;
  }
</style>