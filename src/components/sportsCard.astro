---
interface Props {
  icon?: string;
  imageSrc?: string;
  value: string;
  label?: string;
}

const { icon, imageSrc, value, label } = Astro.props;
---

<div class="stat-card">
  <div class="icon-box">
    {imageSrc ? <img src={imageSrc} alt={value} class="sport-logo" /> : icon}
  </div>
  <div class="value-box">{value}</div>
  {label && <div class="label-box">{label}</div>}
</div>

<style>
  .stat-card {
    /* Fixed dimensions – never grows beyond this */
    width: 100px;
    min-width: 100px;
    max-width: 100px;
    height: 80px;
    min-height: 80px;
    max-height: 80px;
    
    padding: 6px 4px;
    background: linear-gradient(135deg, rgba(21, 27, 45, 0.8) 0%, rgba(15, 20, 25, 0.8) 100%);
    border-radius: 10px;
    border: 0.67px solid rgba(255, 255, 255, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.1);
    box-sizing: border-box;
    overflow: hidden;            /* Clips any accidental overflow */
  }

  .icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .sport-logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.5));
  }

  .value-box {
    color: white;
    font-size: 8px;
    font-weight: 900;
    line-height: 1;
    text-align: center;
    font-family: 'Open sans', sans-serif;
    
    /* Force single line + ellipsis */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
    width: 100%;
    display: block;
  }

  .label-box {
    color: rgba(255, 255, 255, 0.6);
    font-size: 6px;
    font-weight: 600;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    
    /* Same truncation */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
    width: 100%;
  }
</style>