---
interface Props {
  icon: string;
  value: string;
  label: string;
}
const { icon, value, label } = Astro.props;
---

<div class="stat-card">
  <div class="icon-box">{icon}</div>
  <div class="value-box">{value}</div>
  <div class="label-box">{label}</div>
</div>

<style>
  .stat-card {
    /* Flex: 1 asegura que todas las cartas crezcan igual y ocupen el mismo espacio */
    flex: 1; 
    min-width: 0; /* Evita que el contenido desborde la caja */
    
    /* Padding balanceado para móvil */
    padding: 30px 20px; 
    
    background: linear-gradient(135deg, rgba(21, 27, 45, 0.8) 0%, rgba(15, 20, 25, 0.8) 100%);
    border-radius: 16px;
    border: 0.67px solid rgba(255, 255, 255, 0.1);
    
    /* Alineación interna */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    
    /* Efecto de elevación sutil */
    box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.1);
  }

  .icon-box { 
    font-size: 20px; 
    margin-bottom: 2px;
  }

  .value-box { 
    color: white; 
    font-size: 22px; 
    font-weight: 900; 
    line-height: 1;
    font-family: 'Inter', sans-serif;
  }

  .label-box { 
    color: rgba(255, 255, 255, 0.6); 
    font-size: 10px; 
    font-weight: 600; 
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
</style>