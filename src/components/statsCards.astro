---
// Definimos las "props" para que el componente sea dinámico
interface Props {
  icon: string;
  value: string;
  label: string;
}

const { icon, value, label } = Astro.props;
---

<div class="stat-card">
    <div class="icon-wrapper">
        <span class="icon">{icon}</span>
    </div>
    <div class="value-wrapper">
        <span class="value">{value}</span>
    </div>
    <div class="label-wrapper">
        <span class="label">{label}</span>
    </div>
</div>

<style>
    .stat-card {
        flex: 1; /* Esto hace que todas las tarjetas midan lo mismo en la fila */
        padding: 16px 8px;
        background: linear-gradient(135deg, rgba(21, 27, 45, 0.80) 0%, rgba(15, 20, 25, 0.80) 100%);
        border-radius: 16px;
        border: 0.67px solid rgba(255, 255, 255, 0.10);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 4px;
    }

    .icon-wrapper, .value-wrapper, .label-wrapper {
        width: 100%;
        text-align: center;
    }

    .icon {
        font-size: 24px;
    }

    .value {
        color: white;
        font-size: 24px;
        font-weight: 900;
        font-family: 'Inter', sans-serif;
        line-height: 1.2;
    }

    .label {
        color: rgba(255, 255, 255, 0.60);
        font-size: 11px;
        font-weight: 600;
        font-family: 'Inter', sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>